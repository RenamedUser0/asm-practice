section .data
    prompt db "Enter n (5..50): ", 0
    prompt_len equ $ - prompt

    msg_array db "Array: ", 0
    msg_array_len equ $ - msg_array

    msg_min db 10, "Min: ", 0
    msg_min_len equ $ - msg_min

    msg_max db 10, "Max: ", 0
    msg_max_len equ $ - msg_max

    msg_idx db " Index: ", 0
    msg_idx_len equ $ - msg_idx

    space db " ", 0
    newline db 10

section .bss
    arr resd 50
    buffer resb 16
    num_buf resb 16

section .text
    global _start

_start:

    mov eax, 4
    mov ebx, 1
    mov ecx, prompt
    mov edx, prompt_len
    int 0x80

    mov eax, 3
    mov ebx, 0
    mov ecx, buffer
    mov edx, 16
    int 0x80

    xor eax, eax       
    mov esi, buffer

parse_loop:
    mov bl, [esi]
    cmp bl, 10        
    je parse_done

    cmp bl, '0'
    jl exit            
    cmp bl, '9'
    jg exit

    sub bl, '0'
    imul eax, eax, 10
    add eax, ebx

    inc esi
    jmp parse_loop

parse_done:
    mov ecx, eax        
    mov ebp, ecx       
    cmp ebp, 5
    jl exit
    cmp ebp, 50
    jg exit

    xor edi, edi       

fill_loop:
    mov eax, edi
    imul eax, eax    

    mov ebx, edi
    imul ebx, 3       

    sub eax, ebx
    add eax, 7

    mov [arr + edi*4], eax

    inc edi
    cmp edi, ebp
    jl fill_loop

    mov eax, [arr]
    mov ebx, eax       
    mov edx, eax        

    xor esi, esi       
    xor edi, edi      

    mov ecx, 1          

find_loop:
    cmp ecx, ebp
    jge done_find

    mov eax, [arr + ecx*4]

    cmp eax, ebx
    jge check_max
    mov ebx, eax
    mov esi, ecx

check_max:
    cmp eax, edx
    jle next_i
    mov edx, eax
    mov edi, ecx

next_i:
    inc ecx
    jmp find_loop

done_find:

    mov eax, 4
    mov ebx, 1
    mov ecx, msg_array
    mov edx, msg_array_len
    int 0x80

    xor esi, esi

print_array:
    cmp esi, ebp
    jge after_array

    mov eax, [arr + esi*4]
    call print_number

    mov eax, 4
    mov ebx, 1
    mov ecx, space
    mov edx, 1
    int 0x80

    inc esi
    jmp print_array

after_array:

    mov eax, 4
    mov ebx, 1
    mov ecx, msg_min
    mov edx, msg_min_len
    int 0x80

    mov eax, ebx
    call print_number

    mov eax, 4
    mov ebx, 1
    mov ecx, msg_idx
    mov edx, msg_idx_len
    int 0x80

    mov eax, esi
    call print_number
    mov eax, 4
    mov ebx, 1
    mov ecx, msg_max
    mov edx, msg_max_len
    int 0x80

    mov eax, edx
    call print_number

    mov eax, 4
    mov ebx, 1
    mov ecx, msg_idx
    mov edx, msg_idx_len
    int 0x80

    mov eax, edi
    call print_number

exit:
    mov eax, 1
    xor ebx, ebx
    int 0x80

print_number:
    mov ecx, num_buf + 15
    mov byte [ecx], 0
    dec ecx

    cmp eax, 0
    jne pn_loop

    mov byte [ecx], '0'
    jmp pn_done

pn_loop:
    xor edx, edx
    mov ebx, 10
    div ebx
    add dl, '0'
    mov [ecx], dl
    dec ecx
    test eax, eax
    jnz pn_loop

    inc ecx

pn_done:
    mov eax, 4
    mov ebx, 1
    mov edx, num_buf + 15
    sub edx, ecx
    int 0x80
    ret
